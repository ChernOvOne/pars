# Copy to .env and fill in. The .env file is git-ignored.
# config.yaml references these by name only (token_env: TIMEWEB_TOKEN).

# Telegram bot for hit notifications (create via @BotFather).
TELEGRAM_BOT_TOKEN=123456789:AA...

TIMEWEB_TOKEN=eyJ...
REGRU_TOKEN=

# Selectel: service user (OpenStack Keystone v3)
SELECTEL_ACCOUNT_ID=
SELECTEL_SERVICE_USER=
SELECTEL_SERVICE_PASS=
SELECTEL_PROJECT_ID=

# Cloud.ru Evolution: OAuth2 client_credentials
CLOUDRU_KEY_ID=
CLOUDRU_KEY_SECRET=
CLOUDRU_PROJECT_ID=

# CLO.ru
CLO_TOKEN=

# 1cloud.ru
ONECLOUD_TOKEN=
